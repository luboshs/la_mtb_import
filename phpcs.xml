<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="MTB Model Importer Coding Standard">
    <description>Coding standard for mtbmodelimporter PrestaShop module.</description>

    <file>.</file>

    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>views/templates/</exclude-pattern>

    <rule ref="PSR2"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
</ruleset>
